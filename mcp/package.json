{
  "name": "@bigstrider/transcodes-mcp",
  "version": "0.31.2",
  "description": "Transcodes Guard MCP server — step-up MFA audit tools/resources/prompts over stdio. Standalone build for Claude Desktop / claude.ai connectors and any MCP client.",
  "type": "module",
  "bin": {
    "transcodes-mcp": "dist/stdio.js"
  },
