{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "node __AI_ACTION_TRACKER_ROOT__/dist/hooks/pre-tool-use.js",
        "timeout": 30
      }
    ],
    "beforeMCPExecution": [
      {
        "type": "command",
        "command": "node __AI_ACTION_TRACKER_ROOT__/dist/hooks/pre-tool-use.js",
        "matcher": "MCP:plugin_transcodes-guard_*",
        "timeout": 30
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "command": "node __AI_ACTION_TRACKER_ROOT__/dist/hooks/session-start.js",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "type": "command",
        "command": "node __AI_ACTION_TRACKER_ROOT__/dist/hooks/before-submit-prompt.js",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "node __AI_ACTION_TRACKER_ROOT__/dist/hooks/stop.js",
        "timeout": 10
      }
    ]
  }
}
