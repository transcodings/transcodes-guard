{
  "name": "transcodes-guard-monorepo",
  "private": true,
  "version": "0.20.2",
  "description": "Monorepo orchestrator for transcodes-guard plugins + marketplace. Root is the release-please train coordinator (never published).",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "cli"
  ],
  "scripts": {
    "build": "turbo run build",
    "prebuild:plugin": "node scripts/stamp-build-info.mjs && node scripts/generate-router-files.mjs",
    "build:plugin": "turbo run build:plugin",
    "prebuild:cdn": "turbo run build --filter=@transcodes-guard/gate-backend...",
    "build:cdn": "node scripts/build-cdn.mjs",
    "dev:stdio": "npm run dev:stdio -w @bigstrider/transcodes-guard-claude-code",
    "dev:http": "npm run dev:http -w @bigstrider/transcodes-guard-claude-code",
    "dev:hook": "npm run dev:hook -w @bigstrider/transcodes-guard-claude-code",
    "inspect": "npm run inspect -w @bigstrider/transcodes-guard-claude-code",
    "format": "biome format --write --files-ignore-unknown=true --no-errors-on-unmatched",
    "check": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched",
    "type-check": "turbo run type-check",
    "version:bump": "node scripts/version-bump.mjs",
    "postinstall": "[ -z \"$CI\" ] && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "dotenv": "^16.6.1",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.3",
    "lefthook": "^1.13.6",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0",
  "license": "FSL-1.1-ALv2"
}
