{
  "name": "transcodes-guard-monorepo",
  "private": true,
  "version": "0.3.0",
  "description": "Monorepo orchestrator for transcodes-guard plugins + marketplace. Root is the release-please train coordinator (never published).",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "private-packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "prebuild:plugin": "node scripts/stamp-build-info.mjs",
    "build:plugin": "turbo run build:plugin",
    "dev:stdio": "npm run dev:stdio -w plugins/claude-code-ai-action-tracker",
    "dev:http": "npm run dev:http -w plugins/claude-code-ai-action-tracker",
    "dev:hook": "npm run dev:hook -w plugins/claude-code-ai-action-tracker",
    "inspect": "npm run inspect -w plugins/claude-code-ai-action-tracker",
    "format": "biome format --write --files-ignore-unknown=true --no-errors-on-unmatched",
    "check": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched",
    "type-check": "turbo run type-check",
    "version:bump": "node scripts/version-bump.mjs",
    "postinstall": "[ -z \"$CI\" ] && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "lefthook": "^1.13.6",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0"
}
