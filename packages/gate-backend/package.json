{
  "name": "@transcodes-guard/gate-backend",
  "version": "0.1.0",
  "description": "Private GateBackend implementation — binds stepup-core + transcodes-mcp-tools + danger-rules into the public @transcodes-guard/gate-contract DI interface. Injected via setGateBackend() at plugin bootstrap (phase 1: bundled; phase 2: CDN-loaded).",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@transcodes-guard/gate-contract": "*",
    "@transcodes-guard/stepup-core": "*",
    "@transcodes-guard/transcodes-mcp-tools": "*",
    "@transcodes-guard/danger-rules": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "FSL-1.1-ALv2"
}
