{
  "name": "@transcodes-guard/danger-patterns",
  "version": "0.1.0",
  "description": "Bash danger-pattern + MCP tool-rule registry — shared system rules + user CRUD for transcodes-guard plugins.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/*.json dist/data/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@transcodes-guard/plugin-paths": "*",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "FSL-1.1-ALv2"
}
