{
  "transcodes-guard-stepup": {
    "PreToolUse": [
      {
        "matcher": "run_command|mcp_.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ./dist/hooks/pre-tool-use.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "type": "command",
        "command": "node ./dist/hooks/pre-invocation.js",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ./dist/hooks/stop.js",
        "timeout": 10
      }
    ]
  }
}
