{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*|.*\\..*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/dist/hooks/pre-tool-use.js"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "mcp__codex_apps__.*|codex_apps\\..*|[A-Za-z0-9_]+\\..*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/dist/hooks/pre-tool-use.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/dist/hooks/session-start.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/dist/hooks/user-prompt-submit.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/dist/hooks/stop.js"
          }
        ]
      }
    ]
  }
}
