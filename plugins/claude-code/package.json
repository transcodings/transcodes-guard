{
  "name": "@bigstrider/transcodes-guard-claude-code",
  "version": "0.15.2",
  "description": "Risky-bash interceptor (PreToolUse hook) and step-up MFA audit MCP server — Claude Code plugin.",
  "type": "module",
  "main": "dist/src/stdio.js",
  "bin": {
    "transcodes-guard-mcp": "dist/src/stdio.js",
    "transcodes-guard-hook": "dist/hooks/pre-tool-use.js"
  },
  "files": [
    "dist",
    "README.md",
    ".claude-plugin",
    ".mcp.json",
    "hooks/hooks.json"
  ],
  "scripts": {
    "build": "tsup",
    "build:plugin": "tsc --noEmit && tsup && chmod 755 dist/src/stdio.js dist/src/http.js dist/hooks/pre-tool-use.js dist/hooks/session-start.js dist/hooks/user-prompt-submit.js dist/hooks/stop.js",
    "type-check": "tsc --noEmit",
    "dev:stdio": "node -r ../../scripts/load-dev-env.cjs --import tsx src/stdio.ts",
    "dev:http": "node -r ../../scripts/load-dev-env.cjs --import tsx src/http.ts",
    "dev:hook": "node -r ../../scripts/load-dev-env.cjs --import tsx hooks/pre-tool-use.ts",
    "start:stdio": "node dist/src/stdio.js",
    "start:http": "node dist/src/http.js",
    "start:hook": "node dist/hooks/pre-tool-use.js",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/stdio.ts",
    "prepublishOnly": "npm run build:plugin"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@bigstrider/transcodes-cli": ">=0.3.0 <0.4.0"
  },
  "peerDependenciesMeta": {
    "@bigstrider/transcodes-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@transcodes-guard/gate-contract": "*",
    "@transcodes-guard/hook-adapters": "*",
    "@transcodes-guard/mcp-server-core": "*",
    "@transcodes-guard/gate-backend": "*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "FSL-1.1-ALv2"
}
