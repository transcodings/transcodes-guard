{
  "name": "@bigstrider/transcodes-guard-antigravity",
  "version": "0.1.0",
  "description": "Risky-shell interceptor + step-up MFA audit MCP server — Google Antigravity 2.0 plugin.",
  "type": "module",
  "main": "dist/src/stdio.js",
  "bin": {
    "ai-action-tracker-mcp": "dist/src/stdio.js",
    "ai-action-tracker-hook": "dist/hooks/pre-tool-use.js"
  },
  "files": [
    "dist",
    "README.md",
    "rules",
    "plugin.json",
    "mcp_config.json",
    "hooks.json"
  ],
  "scripts": {
    "build": "tsup",
    "build:plugin": "tsc --noEmit && tsup && chmod 755 dist/src/stdio.js dist/hooks/pre-tool-use.js dist/hooks/pre-invocation.js dist/hooks/stop.js",
    "typecheck": "tsc --noEmit",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:hook": "tsx hooks/pre-tool-use.ts",
    "prepublishOnly": "npm run build:plugin"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@bigstrider/transcodes-cli": ">=0.3.0 <0.4.0"
  },
  "peerDependenciesMeta": {
    "@bigstrider/transcodes-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-action-tracker/hook-adapters": "*",
    "@ai-action-tracker/mcp-server-core": "*",
    "@ai-action-tracker/stepup-core": "*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
